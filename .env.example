# ══════════════════════════════════════════
# TAJIK AI CRM — Environment Variables
# Скопируй в .env и заполни свои данные
# ══════════════════════════════════════════

# ── SUPABASE ──
SUPABASE_URL=https://ТВОЙ_ПРОЕКТ.supabase.co
SUPABASE_ANON_KEY=eyJ...  # Settings → API → anon public
SUPABASE_SERVICE_KEY=eyJ...  # Settings → API → service_role

# ── TELEGRAM ──
# Получи у @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAF...
# Твой личный chat_id (получи у @userinfobot)
MANAGER_CHAT_ID=123456789

# ── CLAUDE AI (для умных ответов бота) ──
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── INSTAGRAM ──
# Meta for Developers → Your App → Webhooks
INSTAGRAM_ACCESS_TOKEN=EAAx...
INSTAGRAM_PAGE_ID=1234567890
INSTAGRAM_VERIFY_TOKEN=tajik_crm_secret_2025
INSTAGRAM_APP_SECRET=abc123...

# ── WHATSAPP (опционально) ──
WHATSAPP_TOKEN=EAAx...
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=tajik_crm_wa_2025

# ── СЕРВЕР ──
# Для Railway: PORT автоматически
PORT=8000
WEBHOOK_BASE_URL=https://твой-домен.railway.app

# ── БИЗНЕС ──
BUSINESS_ID=uuid-твоего-бизнеса-из-supabase
